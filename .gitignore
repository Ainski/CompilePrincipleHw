# ============================================================
#  编译原理大作业 - 完整 .gitignore
# ============================================================

# ==================== 编译输出文件 ====================
# Object files
*.o
*.obj
*.lo
*.slo

# Executables
*.exe
*.out
*.app
*.dll
*.so
*.dylib
*.lib
*.a

# Precompiled headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger files
*.pdb
*.dwo

# ==================== 编译器/构建系统生成文件 ====================
# Flex 生成的文件
lex.yy.c
lex.yy.cpp

# CMake 构建目录和文件
**/build/
**/build-win/
**/CMakeFiles/
**/CMakeCache.txt
**/cmake_install.cmake
**/Makefile

# 编译输出目录
**/bin/
**/obj/

# ==================== 测试输出文件 ====================
# 词法分析/语法分析输出
**/output.tsv
**/parse_tree.txt
**/parser_output.txt

# ==================== IDE 配置文件 ====================
# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/
*.ncb
*.sdf
*.VC.opendb
*.VC.db
ipch/

# VSCode (保留必要配置)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# CLion
.idea/
*.iml

# Vim
*~
*.swp
*.swo
*#

# Emacs
*~
\#*\#

# ==================== 操作系统文件 ====================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ==================== 日志和临时文件 ====================
*.log
*.tmp
*.temp
*.bak
*.cache

# ==================== 环境配置文件 ====================
.envrc
*.env
.env.local
.env.*.local

# ==================== LaTeX 中间文件 ====================
*.aux
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.xdv
*.out

# ==================== Python/uv 相关 ====================
.venv/
__pycache__/
*.pyc
*.pyo
.python-version
uv.lock

# ==================== Node.js 相关 ====================
node_modules/
npm-debug.log*

# ==================== Git 自身 ====================
.git/

# ==================== 项目特定 ====================
# 测试项目
rust-test/

# 临时脚本
tmp.sh
setup.sh

# Semantic analysis and IR output
*_ir.txt
*_semantic.txt
errors.txt
parser_output.txt
